# SOC Manager — environment variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── NetBox connection ──────────────────────────────────────────────────────────
NETBOX_URL=https://netbox.reduno.online
NETBOX_TOKEN=your-netbox-api-token-here

# ── SSL verification ───────────────────────────────────────────────────────────
# Set to true if NetBox has a valid signed certificate
VERIFY_SSL=false

# ── Port the container exposes on the host ─────────────────────────────────────
# nginx should proxy_pass to http://localhost:${APP_PORT}
APP_PORT=8000

# ── mapping.yaml location on the HOST ─────────────────────────────────────────
# This directory is mounted into the container at /data
# Put your mapping.yaml here before first run
MAPPING_PATH=./data

# ── netbox_schema_pull.py location on the HOST ────────────────────────────────
# Used inside the container for full form generation
# Point this at your working copy of netbox_schema_pull.py
SCHEMA_PULL_PATH=./netbox_schema_pull.py
